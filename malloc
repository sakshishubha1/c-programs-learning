#include<stdio.h>
#include<stdlib.h>
int main(){
    int i,n;
    printf("how many numbers do you want to enter?");
    scanf("%d",&n);
    if(n==0){
        printf("No result");
        return 0;
    }
    int *p=malloc(n*sizeof*p);
    if(p==NULL){
        return 1;
    }
    printf("Enter the numbers");
    for(i=0;i<n;i++){
        scanf("%d",&p[i]);
    }
    printf("The numbers you entered were");
        for(i=0;i<n;i++){
        printf("%d\t",p[i]);
    }
    free(p);
    return 0;
    
}