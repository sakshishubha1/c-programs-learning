#include<stdio.h>
#include<stdlib.h>
int main(){
    int n,i;
    printf("Enter the size of the array");
    scanf("%d",&n);
        if(n==0)
    return 1;

    int *p=malloc(n*sizeof(int));
    if(p==NULL)
    return 1;
    printf("Enter the numbers");
    for(i=0;i<n;i++){
        scanf("%d",&p[i]);
    }
    printf("The numbers you entered are ");
    for(i=0;i<n;i++){
        printf("%d",p[i]);
    }
    free(p);
    p=NULL;
    return 0;
}